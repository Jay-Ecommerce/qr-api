{
  "name": "qr-api",
  "version": "0.1.0",
  "private": true,
  "description": "Stateless QR code generation API (SVG + matrix) for the RapidAPI marketplace.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "deploy": "wrangler deploy"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "qrcode-generator": "^1.4.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
